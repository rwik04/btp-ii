# ==========
# API keys
# ==========
# Model/provider selection is config-driven (YAML). Keep only credentials in .env.
GROQ_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ========================
# Retrieval/preprocess misc
# ========================
# If true, data/preprocess.py uses Modal embedding path.
USE_MODAL_EMBEDDING=false
MODAL_EMBED_BATCH_SIZE=512

# ======================
# Dataset/auth (optional)
# ======================
# Keep if your local setup expects HF token style vars.
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=

# ======================================
# Qdrant settings (dense retrieval store)
# ======================================
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=twinviews-13k
QDRANT_PATH=data/qdrant
QDRANT_PREFER_GRPC=false
QDRANT_TIMEOUT_SEC=120
QDRANT_UPSERT_BATCH_SIZE=256
QDRANT_UPSERT_TIMEOUT_SEC=300
